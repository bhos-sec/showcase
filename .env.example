# =============================================================================
# Showcase — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit the `.env` file to version control.
# =============================================================================

# Django
# Generate a secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# GitHub API
# Create a fine-grained PAT at: https://github.com/settings/tokens?type=beta
# Scopes needed: Organization → bhos-sec (read-only repo + org members)
GITHUB_API_TOKEN=
GITHUB_ORG_NAME=bhos-sec

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS (production only — comma-separated origins)
CORS_ALLOWED_ORIGINS=https://bhos-sec.github.io

# Database (production only — path inside Docker volume)
# DB_PATH=/data/db.sqlite3
