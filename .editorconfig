# top-most EditorConfig file
root = true

# Standard EditorConfig properties
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
# React files
[*.{js,jsx,ts,tsx}]
indent_size = 2

# Django/Python files
[*.py]
indent_size = 4
indent_style = space

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
